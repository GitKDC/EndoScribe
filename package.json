{
  "name": "endoscopy-electron",
  "version": "1.0.0",
  "main": "apps/electron/main.js",
  "scripts": {
    "build": "tsc",
    "start": "electron .",
    "build:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "archiver": "^8.0.0",
    "electron": "^42.3.0",
    "sqlite3": "^6.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.endoscribe.app",
    "productName": "EndoScribe",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraMetadata": {
      "main": "apps/electron/main.js"
    }
  }
}
